# Server
PORT=5007
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://pgv_db_user:pgv_db_user@pgv1.ek75s9a.mongodb.net/pgv?appName=pgv1
# For Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/top_property_finder

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRE=7d
            
# Nodemailer (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=Top Property Finder <noreply@toppropertyfinder.com>

# Admin Email (receives lead notifications)
ADMIN_EMAIL=admin@toppropertyfinder.com

# Twilio (OTP / WhatsApp)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# WhatsApp Business API (optional alternative)
WHATSAPP_API_URL=https://api.whatsapp.com/send
WHATSAPP_BUSINESS_NUMBER=+918619930583

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# On-demand ISR revalidation — must match REVALIDATE_SECRET in frontend/.env.local
REVALIDATE_SECRET=change_me_to_a_random_string

# OTP Expiry (seconds)
OTP_EXPIRE=300

# Site Info
SITE_NAME=Top Property Finder
SITE_URL=https://toppropertyfinder.com
SITE_PHONE=+91-8619930583
SITE_EMAIL=info@toppropertyfinder.com
